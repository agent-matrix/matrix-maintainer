# GitHub
GITHUB_TOKEN=
GITHUB_ORG=agent-matrix
GITHUB_BASE_BRANCH=main

# Runtime
LOG_LEVEL=INFO
WORK_DIR=work
STATE_DIR=state
STATUS_SITE_DIR=status-site
MAX_FIX_ATTEMPTS=3
REPO_TIMEOUT_SECONDS=900
START_TIMEOUT_SECONDS=60

# GitPilot
GITPILOT_BIN=gitpilot
GITPILOT_MESSAGE_MODEL=
GITPILOT_ENABLED=true

# matrixlab
MATRIXLAB_BIN=matrixlab
MATRIXLAB_ENABLED=true
MATRIXLAB_FALLBACK_LOCAL=true

# Site
SITE_BASE_URL=
SITE_TITLE=Agent-Matrix Health
SITE_DESCRIPTION=Daily health dashboard for Agent-Matrix repositories and infra.

# Policies
ALLOW_AUTOFIX_PR=true
ALLOW_DIRECT_PUSH=false
MAX_AUTOFIX_FILES=10
